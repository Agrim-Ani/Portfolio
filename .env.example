# PostgreSQL connection string (Neon / Supabase / local)
# Example (Neon): postgresql://user:password@host/db?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/portfolio?schema=public"

# bcrypt hash of your admin password.
# Generate with: node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
# IMPORTANT: the hash contains "$" characters — escape each one as "\$" in this
# file (e.g. \$2a\$10\$...) so the env loader doesn't treat them as variables.
ADMIN_PASSWORD_HASH=""

# Secret used to sign the admin session JWT (any long random string).
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=""

# Resend API key for contact-form email notifications (https://resend.com).
# If left empty, submissions are still stored in the DB and the email step is skipped.
RESEND_API_KEY=""

# From/To addresses for contact notifications.
# CONTACT_FROM must be a Resend-verified domain/sender (onboarding@resend.dev works for testing).
CONTACT_FROM="Portfolio <onboarding@resend.dev>"
CONTACT_TO_EMAIL="agrimani.125@gmail.com"
